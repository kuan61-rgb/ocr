{
  "manifest_version": 3,
  "name": "OCR 英文單字學習工具",
  "version": "0.1.0",
  "description": "用滑鼠框選網頁上的英文單字,OCR 辨識後顯示中文翻譯,並建立個人單字卡。",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "scripting",
    "offscreen"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "OCR 單字工具",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options/options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/overlay.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "start-ocr": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "啟動 OCR 框選"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/*",
        "wordlist/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
